{
  "name": "opencode-autopilot",
  "version": "0.2.1",
  "description": "OpenCode 自动巡航模式 —— 夜间全自主 AI 编程沙箱",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "verify": "npm run lint && npm test -- --run && npm run build",
    "test:real": "node scripts/deploy-test.mjs",
    "test:fork": "node scripts/opencode-fork-smoke.mjs",
    "cleanup": "node scripts/cleanup.mjs"
  },
  "keywords": [
    "opencode",
    "plugin",
    "autopilot",
    "sandbox",
    "autonomous"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist/",
    ".opencode/prompts/"
  ]
}
